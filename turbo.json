{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "outputs": [
                "dist/**"
            ],
            "dependsOn": [
                "^build"
            ]
        },
        "test": {
            "dependsOn": [
                "build"
            ],
            "inputs": [
                "src/**/*.ts",
                "test/**/*.ts"
            ]
        },
        "lint": {
            "inputs": [
                "src/**/*.ts",
                "test/**/*.ts"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "clean": {
            "cache": false
        }
    },
    "globalDependencies": [
        "tsconfig.base.json",
        "package.json",
        "pnpm-lock.yaml"
    ]
}